CONTROLLER_TOKEN=your_controller_bot_token
CONTROLLER_CLIENT_ID=your_controller_application_id
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=discord_multibot
# Optional: true = deploy slash command global only (lebih lama muncul)
GLOBAL_COMMANDS=false
# Optional: saat mode guild, deploy global juga (bisa bikin command terlihat double di beberapa client)
ALSO_DEPLOY_GLOBAL_COMMANDS=false
# Optional: clear command lama dulu sebelum deploy command baru
CLEAR_COMMANDS_BEFORE_DEPLOY=true

# Optional status text semua bot
BOT_STATUS_TEXT=Made By Zcus_

# Optional random delay untuk join/restore voice (ms)
JOIN_DELAY_MIN_MS=350
JOIN_DELAY_MAX_MS=1200

# Optional random delay untuk retry join voice (ms)
RETRY_DELAY_MIN_MS=500
RETRY_DELAY_MAX_MS=1200

# Optional timeout per bot saat /join (ms)
JOIN_ATTEMPT_TIMEOUT_MS=30000

# Optional jumlah maksimal antrian ulang kalau join gagal
JOIN_QUEUE_MAX_ATTEMPTS=3

# Optional monitor system ke channel Discord
MONITOR_CHANNEL_ID=
MONITOR_INTERVAL_SEC=60
MONITOR_NET_SAMPLE_SEC=5

# Optional auto restore voice saat startup (default false)
AUTO_RESTORE_VOICE_ON_BOOT=false

# Optional tampilkan log background join/reconnect (default false)
VERBOSE_BACKGROUND_LOGS=false
